# Backend
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/watchly
JWT_SECRET=<secret>
JWT_EXPIRES_IN=7d
PORT=3001
NODE_ENV=development
TMDB_API_KEY=<api_key>
TMDB_BASE_URL=https://api.themoviedb.org/3
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176

# Frontend
VITE_API_URL=http://localhost:3001/api
VITE_TMDB_IMAGE_URL=https://image.tmdb.org/t/p
VITE_AUTHORIZED_ACCESS_CODE=watchly-private-code

# Test account — bypass DB, no registration needed
TEST_USER_EMAIL=test@watchly.dev
TEST_USER_PASSWORD=test1234
TEST_USER_USERNAME=testuser

# Frontend test account (VITE_ prefix = accessible in browser)
VITE_TEST_USER_EMAIL=test@watchly.dev
VITE_TEST_USER_PASSWORD=test1234
VITE_TEST_USER_USERNAME=testuser
